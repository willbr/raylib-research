# Ekans - Poison type
# Body coils
ellipse 0.0 8.0 14.0 6.0  120 60 160 255
ellipse -4.0 4.0 10.0 8.0  130 70 170 255
ellipse 4.0 0.0 8.0 6.0  120 60 160 255
# Belly stripe
ellipse 0.0 10.0 10.0 3.0  200 180 80 255
ellipse -2.0 6.0 6.0 4.0  200 180 80 255
# Head
circle 2.0 -8.0 8.0  130 70 170 255
# Hood/flare
tri -6.0 -6.0 -12.0 -10.0 -4.0 -2.0  140 80 180 255
tri 10.0 -6.0 16.0 -10.0 8.0 -2.0  140 80 180 255
# Eyes - yellow slit
circle -2.0 -10.0 2.5  240 220 60 255
circle 6.0 -10.0 2.5  240 220 60 255
# Slit pupils
rect -2.0 -10.0 1.0 4.0  20 20 20 255
rect 6.0 -10.0 1.0 4.0  20 20 20 255
# Mouth
line 0.0 -4.0 4.0 -4.0 1.0  80 30 80 255
# Tongue
line 4.0 -4.0 8.0 -2.0 0.8  200 60 80 255
line 8.0 -2.0 10.0 -4.0 0.8  200 60 80 255
line 8.0 -2.0 10.0 0.0 0.8  200 60 80 255
# Rattle tail
circle 12.0 12.0 3.0  200 180 80 255
circle 12.0 14.0 2.5  180 160 60 255
circle 12.0 16.0 2.0  160 140 40 255
