# Ryu idle - breathing bob, ready stance
loop true

frame 0.15
  leg_back -8 -15
  shoe_back -8 -2
  leg_front 8 -15
  shoe_front 8 -2
  torso 0 -45
  arm_back -18 -45
  arm_front 18 -45
  head 0 -75
  hurtbox -16 -96 32 96

frame 0.15
  leg_back -8 -15
  shoe_back -8 -2
  leg_front 8 -15
  shoe_front 8 -2
  torso 0 -46
  arm_back -18 -46
  arm_front 18 -46
  head 0 -76
  hurtbox -16 -97 32 97
